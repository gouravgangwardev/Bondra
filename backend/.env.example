# ============================================================
# Bondra Backend — Environment Variables
# Copy to .env and fill in your values.
# Generate secrets: openssl rand -base64 32
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=random_chat
DB_USER=postgres
DB_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT (CHANGE IN PRODUCTION) ────────────────────────────────
JWT_SECRET=your-jwt-secret-key-minimum-32-characters-long-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-jwt-refresh-secret-minimum-32-characters
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS (comma-separated origins, NO wildcard in production) ─
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── WebSocket ─────────────────────────────────────────────────
WS_PING_TIMEOUT=60000
WS_PING_INTERVAL=25000
WS_MAX_BUFFER_SIZE=1000000

# ── Session ───────────────────────────────────────────────────
SESSION_TIMEOUT=3600000
SESSION_CLEANUP_INTERVAL=300000

# ── Queue ─────────────────────────────────────────────────────
QUEUE_MATCH_TIMEOUT=30000
QUEUE_CLEANUP_INTERVAL=60000

# ── Security ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
ENABLE_HELMET=true

# ── TURN Server (required for production WebRTC behind NAT) ───
# Self-host with coturn (see docker/turnserver.conf) or use a provider.
# Format: turn:your-server-ip:3478 or turns:your-server-ip:5349
TURN_SERVER_URL=turn:localhost:3478
TURN_SERVER_USERNAME=bondra
TURN_SERVER_CREDENTIAL=changeme

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# ── Monitoring ────────────────────────────────────────────────
ENABLE_METRICS=true
METRICS_PORT=9090

# ── Features ──────────────────────────────────────────────────
ENABLE_FRIEND_SYSTEM=true
ENABLE_REPORTING=true

# ── Error Tracking (optional) ─────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy
