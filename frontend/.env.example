# ============================================================================
# RandomChat Frontend — Environment Variables
# ============================================================================
#
# This project uses Vite. All env vars exposed to the browser MUST start with
# VITE_ (not REACT_APP_).  Variables without this prefix are ignored by Vite.
#
# SETUP
#   cp .env.example .env
#   Fill in the values below, then run: npm run dev
#
# ============================================================================

# ----------------------------------------------------------------------------
# BACKEND URLS (required)
# ----------------------------------------------------------------------------

# REST API base URL (no trailing slash)
# Local:      http://localhost:3000/api/v1
# Production: https://your-backend.railway.app/api/v1
VITE_API_URL=http://localhost:3000/api/v1

# Socket.IO server URL (no trailing slash, no path)
# Local:      http://localhost:3000
# Production: https://your-backend.railway.app
VITE_SOCKET_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# APP METADATA (optional — shown in UI)
# ----------------------------------------------------------------------------
VITE_APP_NAME=RandomChat
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Connect with strangers from around the world

# ----------------------------------------------------------------------------
# FEATURE FLAGS (optional — default is true for chat modes, false for analytics)
# ----------------------------------------------------------------------------
VITE_ENABLE_GUEST_MODE=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_VIDEO_CHAT=true
VITE_ENABLE_AUDIO_CHAT=true
VITE_ENABLE_TEXT_CHAT=true
VITE_ENABLE_ANALYTICS=false

# ----------------------------------------------------------------------------
# WEBRTC — TURN SERVER (required for ~20 % of users behind strict NAT)
# ----------------------------------------------------------------------------
# Without a TURN server, users on corporate networks, mobile carriers, or
# strict firewalls (~1 in 5 real-world users) will silently fail to connect.
#
# Free tier (10 GB/month): https://www.metered.ca/tools/openrelay/
#
# Leave blank during local development — STUN-only works on most dev machines.
VITE_TURN_SERVER_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# ----------------------------------------------------------------------------
# ERROR TRACKING (optional)
# ----------------------------------------------------------------------------
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ----------------------------------------------------------------------------
# ANALYTICS (optional)
# ----------------------------------------------------------------------------
# VITE_GA_ID=G-XXXXXXXXXX

# ----------------------------------------------------------------------------
# PRODUCTION EXAMPLE (set these in Vercel → Settings → Environment Variables)
# ----------------------------------------------------------------------------
# VITE_API_URL=https://your-backend.railway.app/api/v1
# VITE_SOCKET_URL=https://your-backend.railway.app
# VITE_TURN_SERVER_URL=turn:openrelay.metered.ca:80
# VITE_TURN_USERNAME=openrelayproject
# VITE_TURN_CREDENTIAL=openrelayproject
# VITE_ENABLE_ANALYTICS=true
# VITE_GA_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# ============================================================================
