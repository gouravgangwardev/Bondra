# ============================================================
# Bondra Frontend — Environment Variables
# Copy to .env.local and fill in your values.
# ============================================================

# Backend API base URL
VITE_API_URL=http://localhost:3000/api/v1

# WebSocket server URL
VITE_SOCKET_URL=http://localhost:3000

# TURN server for WebRTC (required for production)
# Self-host with coturn or use a paid provider (Twilio, Metered, etc.)
VITE_TURN_SERVER_URL=turn:localhost:3478
VITE_TURN_USERNAME=bondra
VITE_TURN_CREDENTIAL=changeme

# App branding
VITE_APP_NAME=Bondra
VITE_APP_VERSION=1.0.0
